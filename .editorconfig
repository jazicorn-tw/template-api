# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across editors and IDEs.

root = true

# ── Defaults (all files) ──────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ── Java ──────────────────────────────────────────────────────────────────────
[*.java]
indent_size = 4

# ── Gradle ────────────────────────────────────────────────────────────────────
[*.gradle]
indent_size = 2

# ── XML (Spring config, Checkstyle, SpotBugs, Maven) ─────────────────────────
[*.xml]
indent_size = 4

# ── YAML ──────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Properties ────────────────────────────────────────────────────────────────
[*.properties]
indent_size = 2

# ── JSON ──────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ── Makefiles (tabs required) ─────────────────────────────────────────────────
[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# ── Windows batch (CRLF required) ─────────────────────────────────────────────
[*.bat]
end_of_line = crlf
